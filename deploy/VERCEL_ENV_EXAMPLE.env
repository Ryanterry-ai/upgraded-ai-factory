# ============================================================
# UPGRADED AI FACTORY — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local for local development
# Set these in Vercel → Settings → Environment Variables for production
# ============================================================

# ============================================================
# SUPABASE (Required for Memory & Learning Layer)
# ============================================================
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (safe for client-side)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (SERVER-SIDE ONLY — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# OPENAI (Required for Embeddings + Optional for LLM)
# ============================================================
# OpenAI API key for embeddings (text-embedding-3-small) and optional LLM
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI model for LLM generation (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# ============================================================
# ANTHROPIC (Optional — alternative LLM provider)
# ============================================================
# Anthropic API key for Claude models
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Anthropic model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================================
# OPENROUTER (Optional — multi-model gateway)
# ============================================================
# OpenRouter API key for access to multiple models
# OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# OpenRouter model (default: openai/gpt-4o)
# OPENROUTER_MODEL=openai/gpt-4o

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================
# RUNTIME CONFIGURATION
# ============================================================
# Which LLM provider to use: openai | anthropic | openrouter
LLM_PROVIDER=openai

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# Application name
APP_NAME=upgraded-ai-factory

# Application URL (for callbacks, redirects)
APP_URL=http://localhost:3000

# Production URL
# PRODUCTION_URL=https://your-domain.com

# ============================================================
# STORAGE (Optional — for file storage)
# ============================================================
# Use Supabase Storage (default) or local filesystem
# STORAGE_PROVIDER=supabase

# Local storage path (if not using Supabase Storage)
# STORAGE_PATH=./storage

# ============================================================
# MONITORING (Optional)
# ============================================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# ============================================================
# ANALYTICS (Optional)
# ============================================================
# PostHog key for product analytics
# POSTHOG_KEY=phc-your-posthog-key

# PostHog host (default: https://us.i.posthog.com)
# POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# SECURITY
# ============================================================
# Rate limiting: max requests per minute per IP
# RATE_LIMIT_MAX=60

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ============================================================
# DEVELOPMENT OVERRIDES (do NOT set in production)
# ============================================================
# NODE_ENV=development
# DEBUG=true
